PORT=3838

# Base directory for server config and runtime data. When unset, Linux uses
# $XDG_STATE_HOME/mdcz or ~/.local/state/mdcz, and other platforms use ~/.mdcz.
# MDCZ_HOME=/var/lib/mdcz

# Optional explicit paths. These override MDCZ_HOME-derived defaults.
# MDCZ_CONFIG_DIR=/etc/mdcz
# MDCZ_DATA_DIR=/var/lib/mdcz/data
# MDCZ_DATABASE_PATH=/var/lib/mdcz/data/mdcz.sqlite

# Optional admin password override for hosted deployments.
# MDCZ_ADMIN_PASSWORD=change-me

# Static WebUI bundle location inside the release artifact.
MDCZ_WEB_DIST_DIR=dist/web

# Optional build labels shown on About.
# MDCZ_SERVER_BUILD=release
# MDCZ_WEB_BUILD=release

# Optional automation webhooks.
# MDCZ_AUTOMATION_WEBHOOK_URL=
# MDCZ_AUTOMATION_WEBHOOK_SECRET=
